{
  "info": {
    "name": "Agentic AI student support system API",
    "description": "Complete API collection for Agentic AI student support system backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "course_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "lecture_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "test_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    console.log('User registered successfully');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@test.com\",\n  \"password\": \"demo123456\",\n  \"full_name\": \"Demo User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('token', jsonData.access_token);",
                  "    console.log('Token saved:', jsonData.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@test.com\",\n  \"password\": \"demo123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Create Course",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('course_id', jsonData.id);",
                  "    console.log('Course ID saved:', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Introduction to AI\",\n  \"code\": \"CS101\",\n  \"semester\": \"Spring 2024\",\n  \"instructor\": \"Prof. Smith\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/courses",
              "host": ["{{base_url}}"],
              "path": ["courses"]
            }
          }
        },
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/courses",
              "host": ["{{base_url}}"],
              "path": ["courses"]
            }
          }
        },
        {
          "name": "Get Single Course",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/courses/{{course_id}}",
              "host": ["{{base_url}}"],
              "path": ["courses", "{{course_id}}"]
            }
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Advanced AI\",\n  \"instructor\": \"Prof. Johnson\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/courses/{{course_id}}",
              "host": ["{{base_url}}"],
              "path": ["courses", "{{course_id}}"]
            }
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/courses/{{course_id}}",
              "host": ["{{base_url}}"],
              "path": ["courses", "{{course_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Lectures",
      "item": [
        {
          "name": "Upload Lecture",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('lecture_id', jsonData.id);",
                  "    console.log('Lecture ID saved:', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "course_id",
                  "value": "{{course_id}}",
                  "type": "text"
                },
                {
                  "key": "week_number",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "title",
                  "value": "Introduction to Neural Networks",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/lectures/upload",
              "host": ["{{base_url}}"],
              "path": ["lectures", "upload"]
            }
          }
        },
        {
          "name": "Get Course Lectures",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lectures/course/{{course_id}}",
              "host": ["{{base_url}}"],
              "path": ["lectures", "course", "{{course_id}}"]
            }
          }
        },
        {
          "name": "Get Lecture Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lectures/{{lecture_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["lectures", "{{lecture_id}}", "status"]
            }
          }
        },
        {
          "name": "Process Lecture",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lectures/{{lecture_id}}/process",
              "host": ["{{base_url}}"],
              "path": ["lectures", "{{lecture_id}}", "process"]
            }
          }
        }
      ]
    },
    {
      "name": "Tests",
      "item": [
        {
          "name": "Generate Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('test_id', jsonData.id);",
                  "    console.log('Test ID saved:', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"week_number\": 1,\n  \"num_mcq\": 5,\n  \"num_true_false\": 3,\n  \"num_essay\": 2,\n  \"difficulty\": \"medium\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tests/generate?course_id={{course_id}}",
              "host": ["{{base_url}}"],
              "path": ["tests", "generate"],
              "query": [
                {
                  "key": "course_id",
                  "value": "{{course_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Test",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tests/{{test_id}}",
              "host": ["{{base_url}}"],
              "path": ["tests", "{{test_id}}"]
            }
          }
        },
        {
          "name": "Get Lecture Tests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tests/lecture/{{lecture_id}}",
              "host": ["{{base_url}}"],
              "path": ["tests", "lecture", "{{lecture_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Evaluations",
      "item": [
        {
          "name": "Submit Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": [\n    {\n      \"question_id\": \"q1\",\n      \"answer\": \"A\"\n    },\n    {\n      \"question_id\": \"q2\",\n      \"answer\": \"True\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/evaluations/submit/{{test_id}}",
              "host": ["{{base_url}}"],
              "path": ["evaluations", "submit", "{{test_id}}"]
            }
          }
        },
        {
          "name": "Get Attempt Result",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/evaluations/attempt/{{attempt_id}}",
              "host": ["{{base_url}}"],
              "path": ["evaluations", "attempt", "{{attempt_id}}"]
            }
          }
        },
        {
          "name": "Get Test Attempts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/evaluations/test/{{test_id}}/attempts",
              "host": ["{{base_url}}"],
              "path": ["evaluations", "test", "{{test_id}}", "attempts"]
            }
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://127.0.0.1:8000/health",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["health"]
            }
          }
        },
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://127.0.0.1:8000/",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": [""]
            }
          }
        }
      ]
    }
  ]
}
